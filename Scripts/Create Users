   $Users = @(
     @{
        DisplayName = "Mark Kent"
         UserPrincipalName = "Mark.Kent@lamargoodhallgmail.onmicrosoft.com"
        MailNickname = "Mark"
    },
     @{
         DisplayName = "Jane Doe"        
         UserPrincipalName = "Jane.Doe@lamargoodhallgmail.onmicrosoft.com"
         MailNickname = "alice"
     },
    @{
        DisplayName = "Alison Brown"
        UserPrincipalName = "Alison.Brown@lamargoodhallgmail.onmicrosoft.com"
         MailNickname = "alice"
     },
     @{
         DisplayName = "John Smith"
         UserPrincipalName = "John.Smith@lamargoodhallgmail.onmicrosoft.com"
         MailNickname = "john"
     }
   )

   foreach ($User in $Users) {
     $PasswordProfile = @{
        Password = "<TemporaryPassword>"
      ForceChangePasswordNextSignIn = $true
    }

     New-MgUser `
         -DisplayName $User.DisplayName `
         -UserPrincipalName $User.UserPrincipalName `
        -MailNickname $User.MailNickname `
         -AccountEnabled:$true `
         -PasswordProfile $PasswordProfile
  }
