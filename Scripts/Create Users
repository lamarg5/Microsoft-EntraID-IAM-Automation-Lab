PS C:\Windows\System32> Connect-MgGraph -Scopes User.ReadWrite.All

   $Users = @(
     @{
        DisplayName = "Mark Kent"
         UserPrincipalName = "Mark.Kentcompany.onmicrosoft.com"
        MailNickname = "Mark"
    },
     @{
         DisplayName = "Jane Doe"        
         UserPrincipalName = "Jane.Doe@company.onmicrosoft.com"
         MailNickname = "Jane"
     },
    @{
        DisplayName = "Alison Brown"
        UserPrincipalName = "Alison.Brown@company.onmicrosoft.com"
         MailNickname = "alice"
     },
     @{
         DisplayName = "John Smith"
         UserPrincipalName = "John.Smith@company.onmicrosoft.com"
     }
   )

   foreach ($User in $Users) {
     $PasswordProfile = @{
        Password = "<TemporaryPassword>"
      ForceChangePasswordNextSignIn = $true
    }

     New-MgUser `
         -DisplayName $User.DisplayName `
         -UserPrincipalName $User.UserPrincipalName `
        -MailNickname $User.MailNickname `
         -AccountEnabled:$true `
         -PasswordProfile $PasswordProfile
  }
